# Copy this file to .env.local and fill in your Supabase project values.
# Both keys are on the Supabase dashboard under Project Settings -> API.
#
# These vars are exposed to the browser (NEXT_PUBLIC_ prefix). That's
# intentional: every write is protected by Row Level Security in
# Postgres, so the anon key is safe to ship.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
